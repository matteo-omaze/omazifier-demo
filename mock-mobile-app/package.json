{
  "name": "mock-mobile-app",
  "version": "0.1.0",
  "private": true,
  "description": "Stand-in for mobile-app: an Expo/React Native screen composed by the SAME omazifier engine + composition schema, with React Native block implementations.",
  "main": "index.js",
  "scripts": {
    "start": "MARKET=${MARKET:-uk} expo start",
    "ios": "MARKET=${MARKET:-uk} expo start --ios",
    "android": "MARKET=${MARKET:-uk} expo start --android",
    "web": "MARKET=${MARKET:-uk} expo start --web",
    "typecheck": "tsc --noEmit",
    "bundle:check": "MARKET=${MARKET:-uk} expo export --platform ios --output-dir dist/${MARKET:-uk}"
  },
  "dependencies": {
    "expo": "^54.0.0",
    "omazifier": "file:../..",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "typescript": "^5.6.3"
  }
}
